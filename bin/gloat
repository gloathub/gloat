#!/usr/bin/env bash

set -euo pipefail

export GLOAT_VERSION=0.1.9

main() (
  self=${BASH_SOURCE[0]}
  [[ -L $self ]] && self=$(readlink -f "$self")
  root=$(cd -P "$(dirname "$self")/.." && pwd -P)

  PATH=$(make --quiet --no-print-directory -C "$root" path)
  export PATH

  setup

  if [[ $* == --shell ]]; then
    make --quiet --no-print-directory -C "$root" shell-deps
    do-shell
  fi

  exec bb "$root/bin/src/gloat.clj" "$@"
)

setup() (
  [[ $(command -v bb) == "$root/.cache/.local/bin/bb" ]] && return

  if interactive; then
    GREEN=$'\e[1;92m'
    YELLOW=$'\e[1;93m'
    BLUE=$'\e[1;96m'
    BOLD=$'\e[1m'
    RESET=$'\e[0m'

    deps="$YELLOW(bb, glj, go, ys)"

    >&2 cat <<...
$BLUE==> Installing gloat dependencies $deps$BLUE locally into:$RESET

    $root/.cache/.local/

${BOLD}Press Enter to continue (or Ctrl-C to cancel)...$RESET
...

      read -r < /dev/tty
  fi

  make -C "$root" path-deps

  if interactive; then
    >&2 echo -e "\n$GREEN==> All gloat dependencies installed.$RESET"
  fi
)

interactive() { [[ -t 0 && -t 1 && -t 2 ]]; }

do-shell() {
  if [[ ${IN_GLOAT_SHELL-} ]]; then
    echo "Already in a gloat shell" >&2
    exit 1
  fi
  make -C "$root" shell-deps
  export IN_GLOAT_SHELL=1
  local shell
  shell=$(ps -o comm= -p $PPID 2>/dev/null)
  shell=${shell#-}
  shell=${shell:-${GLOAT_SHELL:-bash}}
  echo "Starting gloat $shell shell (type 'exit' to leave)" >&2
  case $shell in
    bash)
      exec bash --rcfile <(cat <<'BASH'
[[ -f ~/.bashrc ]] && source ~/.bashrc
PS1="(gloat) $PS1"
BASH
)
      ;;
    zsh)
      local zdot
      zdot=$(mktemp -d)
      cat > "$zdot/.zshrc" <<'ZSH'
[[ -f "$HOME/.zshrc" ]] && ZDOTDIR=$HOME source "$HOME/.zshrc"
PS1="(gloat) $PS1"
ZSH
      exec env ZDOTDIR="$zdot" zsh
      ;;
    fish)
      exec fish --init-command '
functions -q fish_prompt
  and functions -c fish_prompt _gloat_orig_prompt
  and function fish_prompt
    echo -n "(gloat) "
    _gloat_orig_prompt
  end
'
      ;;
    *)
      exec "$shell"
      ;;
  esac
}

main "$@"
