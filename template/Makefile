# This Makefile uses Makes to auto-install Go

M := .cache/makes
$(shell [ -d $M ] || git clone -q https://github.com/makeplus/makes $M)

include $M/init.mk
include $M/go.mk
include $M/clean.mk
include $M/shell.mk

BINARY := BINARY-NAME
GO-SUM := go.sum

MAKES-CLEAN := \
  $(BINARY) \
  $(GO-SUM) \

BUILD-OPTS := -ldflags '-s -w'
ifneq (,$(wildcard internal))
BUILD-OPTS += -tags glj_no_aot_stdlib
endif


default:: build

build: $(BINARY)

$(BINARY): $(GO-SUM)
	go build $(BUILD-OPTS) -o $(BINARY) .

$(GO-SUM): $(GO)
	go mod tidy
