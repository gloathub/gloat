#!/usr/bin/env bash

# make-do — Helper functions for Makefile rules

set -euo pipefail

save-patch() (
  repo_url=$1
  shift
  gloat_only=$1
  shift
  clj_files=("$@")

  for f in "${clj_files[@]}"; do
    # Skip gloat-only files
    skip=false
    for gloat_file in $gloat_only; do
      if [[ $f == "$gloat_file" ]]; then
        skip=true
        break
      fi
    done
    $skip && continue

    clj=${f#ys/src/}
    name=$(echo "$clj" | tr '/' '-' | perl -pe 's/\.clj$//')
    diff -u <(curl -sL "$repo_url/$clj") "$f" 2>/dev/null \
      | perl -pe 's/\t.*// if 1..2' > "ys/patch/$name.patch" || true
    if [ ! -s "ys/patch/$name.patch" ]; then
      rm -f "ys/patch/$name.patch"
    else
      echo "Saved ys/patch/$name.patch"
    fi
  done
  echo "Patches saved to ys/patch/"
)

test-docker() (
  if [[ -d .cache/local/bin/bb ]]; then
    echo 'Run first: make distclean'
    exit 1
  fi
  docker run --rm -it \
    -w /work \
    -v "$PWD:/work" \
    ubuntu:24.04 \
    bash -c '
      set -x &&
      apt update &&
      apt install -y curl git make xz-utils &&
      git config --global --add safe.directory /work &&
      export PERL_BADLANG=0 &&
      make test &&
      chown -R '"$(id -u):$(id -g) .cache"
)

update-clj() (
  repo_url=$1
  stem=$2
  target=$3

  curl -sL "$repo_url/$stem.clj" -o "$target"
  patch_file=ys/patch/$(echo "$stem" | tr '/' '-').patch
  if [ -f "$patch_file" ]; then
    echo "Applying $patch_file"
    patch --no-backup-if-mismatch -p0 < "$patch_file"
  fi
)

compile-glj() (
  stem=$1
  target=$2

  mkdir -p "$(dirname "$target")"
  tmpdir=$(mktemp -d)
  cp -r ys/glj/* "$tmpdir/"
  cd "$tmpdir"
  ns=$(echo "$stem" | tr '/' '.')
  echo "(compile (quote $ns))" | glj >/dev/null 2>&1 || true
  cd - >/dev/null
  cp "$tmpdir/$stem/loader.go" "$target"
  rm -rf "$tmpdir"
)

compile-glj-patched() (
  target=$1

  mkdir -p "$(dirname "$target")"
  tmpdir=$(mktemp -d)
  cp -r ys/glj/* "$tmpdir/"
  cd "$tmpdir"
  ns=$(echo "yamlscript/util" | tr '/' '.')
  echo "(compile (quote $ns))" | glj >/dev/null 2>&1 || true
  cd - >/dev/null
  cp "$tmpdir/yamlscript/util/loader.go" "$target"
  rm -rf "$tmpdir"

  patch --no-backup-if-mismatch -p1 < ys/patch/yamlscript-util-seqable.patch
)

release() (
  version=${1:?Usage: make release VERSION=...}
  message=${2:-Release v$version}
  glj_version=${3:-}

  # Validate version format (digits and dots, no v prefix)
  if [[ ! $version =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
    echo "Error: VERSION must be digits and dots (e.g., 0.1.5)" >&2
    exit 1
  fi

  # Releases must be cut from the configured release branch.
  release_branch=${GLOAT_RELEASE_BRANCH:-$(printenv GLOAT-RELEASE-BRANCH || true)}
  release_branch=${release_branch:-main}
  current_branch=$(git rev-parse --abbrev-ref HEAD)
  if [[ $current_branch != "$release_branch" ]]; then
    echo "Error: 'make release' must be run on the '$release_branch' branch" >&2
    echo "  Current branch: $current_branch" >&2
    echo "  Override with: GLOAT-RELEASE-BRANCH=$current_branch make release ..." >&2
    exit 1
  fi

  # --- Update Glojure version if specified ---
  # common/common.mk is the single source of truth; ys/pkg/go.mod is
  # re-pinned automatically by the Makefile's ys-pkg target.
  if [[ -n $glj_version ]]; then
    perl -i -pe "s/^GLOJURE-VERSION := .*/GLOJURE-VERSION := $glj_version/" \
      common/common.mk
  fi

  # --- Update version in all files ---
  # Single source of truth: common/common.mk. bin/gloat, .rc, and the
  # Makefile's YS-PKG-VERSION all derive from GLOAT-VERSION here.
  perl -i -pe "s/^GLOAT-VERSION := .*/GLOAT-VERSION := $version/" \
    common/common.mk
  perl -i -pe \
    "s/VERSION=v[0-9]+\\.[0-9]+\\.[0-9]+/VERSION=v$version/" \
    www/docs/doc/getting-started.md
  perl -i -pe \
    "s/^VERSION := [0-9]+\\.[0-9]+\\.[0-9]+/VERSION := $version/" \
    doc/gloat-tutorial.md

  # Collect commit subjects since last release tag
  prev_tag=$(git tag -l 'v[0-9]*' --sort=-v:refname | head -1)
  if [[ -n $prev_tag ]]; then
    changes=$(git log "$prev_tag"..HEAD --format='%s' \
      | grep -v '^Version ' || true)
  else
    changes="Initial release"
  fi

  # Build Changes entry
  {
    echo "- version: $version"
    echo "  date:    $(date)"
    echo "  changes:"
    if [[ -n $changes ]]; then
      while IFS= read -r line; do
        echo "  - $line"
      done <<< "$changes"
    else
      echo "  - Release v$version"
    fi
    echo ""
    cat Changes
  } > Changes.tmp && mv Changes.tmp Changes

  "${EDITOR:-vim}" Changes

  echo
  read -rp $'\e[33mContinue release of v'"$version"$'? Enter to continue, ctrl-C to cancel. \e[0m'

  # --- Rebuild and test ---
  make update ys-pkg
  make test
  make -C demo/so-bindings/ada/ test
  make clean
  GLOAT_X_PRUNE=1 make test

  # --- Commit and tag ys/pkg ---
  git add \
    common/common.mk \
    Changes \
    man/man1/gloat.1 \
    man/man1/gloat-install.1 \
    man/man1/gloat-repl.1 \
    man/man1/gloat-tutorial.1 \
    man/man1/gloat-go-interop.1 \
    man/man1/gloat-java-interop.1 \
    www/docs/doc/getting-started.md \
    doc/gloat-tutorial.md \
    ys/
  git diff --cached --quiet || git commit -m "Version $version"
  git tag -f -a "ys/pkg/v$version" -m "Release ys/pkg v$version"
  git push origin main
  git push origin "ys/pkg/v$version"

  # --- Wait for Go proxy ---
  echo "Waiting for Go proxy to index ys/pkg v$version..."
  for i in $(seq 1 30); do
    if go list -m \
      "github.com/gloathub/gloat/ys/pkg@v$version" \
      2>/dev/null; then
      echo "  ys/pkg v$version is live on Go proxy"
      break
    fi
    echo "  Attempt $i/30, retrying in 10s..."
    sleep 10
  done

  # --- Tag and release gloat ---
  git tag -f -a "v$version" -m "Release v$version"
  git push origin "v$version"

  # Extract changes for this version from Changes file
  release_notes=$(
    version=$version perl -ne '
      BEGIN { $v = $ENV{version} }
      if (/^- version:/) { exit if $found }
      if (/^- version:\s+\Q$v\E\s*$/) { $found = 1; next }
      print "- $1\n" if $found && /^  - (.*)/;
    ' Changes
  )
  release_notes+=$'\n\n'"**Full Changelog**: https://github.com/gloathub/gloat/compare/${prev_tag}...v${version}"

  gh release create "v$version" \
    --title "gloat v$version" \
    --notes "$release_notes"

  # --- Publish website ---
  make publish-www
)

# Siblings whose worktrees back a gloat feature. Format: "<name>:<base-branch>".
# The base branch is the canonical main-tracking branch in each sibling's
# upstream checkout (./../<name> from the gloat root).
SIBLINGS=(
  "glojure:gloat"
  "go-readline:main"
  "gojava:main"
)

# Echo absolute path to ../<sibling> (the canonical, always-on-main checkout)
# or return 1 if it doesn't exist.
work-sibling-canonical() {
  local cur=$1 sibling=$2
  local canonical
  canonical=$(cd "$cur/../../../$sibling" 2>/dev/null && pwd -P) || return 1
  [[ -d $canonical/.git ]] || return 1
  echo "$canonical"
}

# Return 0 if cur looks like <something>/gloat/worktree/<name>, else 1.
work-in-worktree() {
  local cur=$1 parent grand
  parent=$(dirname "$cur")
  grand=$(dirname "$parent")
  [[ $(basename "$parent") == worktree && $(basename "$grand") == gloat ]]
}

# Create branch <name> off <base> in canonical if missing, then add a worktree
# at <cur>/workspace/<sibling> pointing at <name> if missing. Idempotent.
work-sibling-setup() {
  local cur=$1 sibling=$2 base=$3
  local canonical workspace name
  canonical=$(work-sibling-canonical "$cur" "$sibling") || return 0
  name=$(basename "$cur")
  workspace=$cur/workspace/$sibling

  if ! git -C "$canonical" show-ref --verify --quiet "refs/heads/$base"; then
    echo "work: $sibling has no $base branch in $canonical; skipping" >&2
    return 0
  fi
  if ! git -C "$canonical" show-ref --verify --quiet "refs/heads/$name"; then
    git -C "$canonical" branch "$name" "$base" >&2 || true
  fi
  if [[ ! -d $workspace ]]; then
    mkdir -p "$cur/workspace"
    git -C "$canonical" worktree add "$workspace" "$name" >&2 || return 0
  fi
}

# Write/refresh <cur>/go.work referencing whichever workspace/<sibling> dirs
# currently exist.
work-write-go-work() {
  local cur=$1 sibling workspace
  local uses=()
  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    workspace=$cur/workspace/$sibling
    [[ -d $workspace ]] && uses+=("./workspace/$sibling")
  done
  [[ ${#uses[@]} -eq 0 ]] && return 0

  {
    echo "go 1.24"
    echo
    echo "use ("
    local u
    for u in "${uses[@]}"; do
      echo "    $u"
    done
    echo ")"
  } > "$cur/go.work"
}

work-init() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-init: not in a gloat worktree; nothing to do" >&2
    return 0
  fi

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    base=${entry##*:}
    work-sibling-setup "$cur" "$sibling" "$base"
  done

  work-write-go-work "$cur"

  # Build glj inside the glojure workspace if find-glj wouldn't already find one.
  workspace_glj=$cur/workspace/glojure
  if [[ -d $workspace_glj ]]; then
    glj_resolved=$(GLOJURE_DIR=$workspace_glj "$cur/bin/gloat" --glj 2>/dev/null || true)
    if [[ $glj_resolved != "$workspace_glj"/bin/*/glj ]]; then
      GLOJURE_DIR=$workspace_glj "$cur/bin/gloat" --glj-build >&2 || true
    fi
  fi
)

work-remove() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-remove: not in a gloat worktree ($cur)" >&2
    exit 1
  fi

  name=$(basename "$cur")
  removed=()
  dirty=()
  kept_branch=()
  not_present=()

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    canonical=$(work-sibling-canonical "$cur" "$sibling") || continue
    workspace=$cur/workspace/$sibling

    if [[ ! -d $workspace ]]; then
      not_present+=("$sibling")
      continue
    fi

    if [[ -n $(git -C "$workspace" status --porcelain 2>/dev/null) ]]; then
      dirty+=("$sibling")
      continue
    fi

    if ! git -C "$canonical" worktree remove "$workspace" >&2; then
      dirty+=("$sibling")
      continue
    fi

    # `branch -d` refuses to delete unmerged branches; leave them in that case.
    if msg=$(git -C "$canonical" branch -d "$name" 2>&1); then
      echo "$sibling: $msg" >&2
      removed+=("$sibling")
    else
      kept_branch+=("$sibling")
    fi
  done

  # Only drop go.work + empty workspace/ if every present sibling was cleanly removed.
  if [[ ${#dirty[@]} -eq 0 ]]; then
    rm -f "$cur/go.work" "$cur/go.work.sum"
    rmdir "$cur/workspace" 2>/dev/null || true
  fi

  echo
  echo "Removed:      ${removed[*]:-none}"
  echo "Branch kept:  ${kept_branch[*]:-none}"
  echo "Dirty:        ${dirty[*]:-none}"
  echo "Not present:  ${not_present[*]:-none}"
  [[ ${#dirty[@]} -eq 0 ]]
)

work-pull() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-pull: not in a gloat worktree ($cur)" >&2
    exit 1
  fi

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    base=${entry##*:}
    canonical=$(work-sibling-canonical "$cur" "$sibling") || continue
    workspace=$cur/workspace/$sibling
    [[ -d $workspace ]] || continue

    echo "== $sibling =="
    git -C "$canonical" fetch origin
    git -C "$canonical" pull --ff-only origin "$base"
    git -C "$workspace" rebase "$base"
  done
)

work-save() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-save: not in a gloat worktree ($cur)" >&2
    exit 1
  fi

  name=$(basename "$cur")
  succeeded=()
  failed=()
  skipped=()

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    base=${entry##*:}
    canonical=$(work-sibling-canonical "$cur" "$sibling") || continue
    workspace=$cur/workspace/$sibling
    [[ -d $workspace ]] || continue

    echo "== $sibling =="
    if [[ -z $(git -C "$workspace" log --oneline "$base..HEAD" 2>/dev/null) ]]; then
      echo "  no commits over $base; skipping"
      skipped+=("$sibling")
      continue
    fi

    if ! git -C "$workspace" rebase "$base"; then
      git -C "$workspace" rebase --abort >/dev/null 2>&1 || true
      echo "  rebase failed; resolve manually and re-run work-save"
      failed+=("$sibling")
      continue
    fi

    if ! git -C "$canonical" merge --ff-only "$name"; then
      echo "  fast-forward of $base failed in $canonical"
      failed+=("$sibling")
      continue
    fi
    succeeded+=("$sibling")
  done

  echo
  echo "Saved:   ${succeeded[*]:-none}"
  echo "Skipped: ${skipped[*]:-none}"
  echo "Failed:  ${failed[*]:-none}"
  [[ ${#failed[@]} -eq 0 ]]
)

work-status() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-status: not in a gloat worktree ($cur)" >&2
    exit 1
  fi

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    workspace=$cur/workspace/$sibling
    [[ -d $workspace ]] || continue
    echo "== $sibling =="
    git -C "$workspace" status --short --branch
    echo
  done
)

work-log() (
  cur=$1
  if ! work-in-worktree "$cur"; then
    echo "work-log: not in a gloat worktree ($cur)" >&2
    exit 1
  fi

  for entry in "${SIBLINGS[@]}"; do
    sibling=${entry%%:*}
    base=${entry##*:}
    workspace=$cur/workspace/$sibling
    [[ -d $workspace ]] || continue
    echo "== $sibling =="
    git -C "$workspace" log --oneline "$base..HEAD" || true
    echo
  done
)

annoucement() (
  glj_version=$1
  version=$(
    perl -ne 'if (/^- version:\s+(\S+)/) { print "$1\n"; exit }' Changes
  )
  echo "#gloat version v$version"
  echo "#glojure version $glj_version"
  perl -ne '
    if (/^- version:/) { exit if $found }
    if (/^  changes:/) { $found = 1; next }
    if ($found && s/^  - //) { print "* $_" }
  ' Changes
  echo "https://gloathub.org/"
)

"$@"
