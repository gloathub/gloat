#!/usr/bin/env bash

set -euo pipefail

export GLOAT_VERSION=0.1.40

# Go 1.26 has a linker bug on arm64 that crashes when building with CGO
export CGO_ENABLED=0

# Canonical getopt spec — single source of truth for all flags.
# bin/gloat runs this first; gloat.clj receives parsed EDN via GLOAT_OPTS.
export GETOPT_SPEC="getopt_default=(--help)

gloat [<options>] <file>...

Glojure Automation Tool - version $GLOAT_VERSION

Compiles Clojure or YAMLScript code to Go code, binaries or Wasm.
Run 'man gloat' for full documentation.
See https://gloathub.org

  FILE:
    path      Source file (.ys, .clj, .glj) or directory
    -         Read from stdin

  Examples:
    gloat foo.ys                        Compile to 'foo' binary
    gloat foo.ys -t go                  Go code to stdout
    gloat foo.ys -o foo/                Go build directory
    gloat foo.ys -o foo.go              Go file
    gloat foo.ys -o foo.so              Shared library + headers
    gloat foo.ys -o foo --platform=freebsd/amd64  Cross-compile
    gloat --run foo.ys -- arg1 arg2     Compile and run

  REPL Usage:
    gloat --repl                        Start Glojure REPL
    gloat --repl=dir/                   REPL with 'dir' as build directory
    gloat --repl=port-file              Connect REPL to nREPL port in file
    gloat --repl=7888                   Connect REPL to nREPL server port
    gloat --repl=+bb                    REPL for bb, clj, lein or let-go
    gloat --nrepl                       Start nREPL server; print port
    gloat --nrepl=port-file             Start nREPL; write port to file
    gloat --nrepl=7888                  Start nREPL on specific port
    gloat --srepl                       Socket server (w/ --nrepl= opts)
--
t,to=         Output format (inferred from -o; see --formats)
o,out=        Output file or directory

platform=     Cross-compile (e.g., linux/amd64; see --platforms)
X,ext=        Enable a processing extension (see --extensions)

ns=           Override namespace
module=       Go module name (e.g., github.com/user/project)

formats       List available output formats
extensions    List available processing extensions
platforms     List available cross-compilation platforms

repl          Start REPL client; see 'man gloat-repl'
nrepl         Start nREPL server; see 'man gloat-repl'
srepl         Start socket REPL server; see 'man gloat-repl'
deps=         Path to gljdeps.edn (for --repl or --nrepl or --srepl)
shell         Start a sub-shell or run a command (-- cmd...)
shell-all     Like --shell but install all dev tools
complete=     Generate shell completion script (bash, fish, zsh)

r,run         Compile and run (pass program args after --)
f,force       Overwrite existing output files
v,verbose     Print timing for each compilation step
q,quiet       Suppress progress messages

upgrade       Upgrade gloat to the latest version
reset         Remove all cached dependencies and reinstall

h,help        Show this help
version       Show version
"

main() (
  unset MAKES_LOCAL_DIR

  self=${BASH_SOURCE[0]}
  [[ -L $self ]] && self=$(readlink -f "$self")
  root=$(cd -P "$(dirname "$self")/.." && pwd -P)

  if [[ $* == --reset ]]; then
    make --quiet --no-print-directory -C "$root" distclean
    exit
  fi

  if [[ $* == --upgrade ]]; then
    echo "Upgrading gloat..."
    cd "$root"
    git fetch --tags
    latest=$(git tag -l 'v*' --sort=-v:refname | head -1)
    if [[ -z $latest ]]; then
      echo "Error: Could not determine latest version" >&2
      exit 1
    fi
    if [[ $latest == "v$GLOAT_VERSION" ]]; then
      echo "Already at latest version ($GLOAT_VERSION)"
      exit
    fi
    if [[ -L ${BASH_SOURCE[0]} ]]; then
      # Curl-based install: checkout latest tag
      git -c advice.detachedHead=false checkout "$latest"
    else
      # Clone-based install: pull current branch
      git pull
    fi
    make --quiet --no-print-directory distclean
    echo "Upgraded to $latest — run 'gloat --version' to verify"
    exit
  fi

  if [[ $* == --root ]]; then
    echo "$root"
    exit
  fi

  PATH=$(make --quiet --no-print-directory -C "$root" path)
  export PATH

  if [[ $* == --glj ]]; then
    glj_path=$(make --quiet --no-print-directory -C "$root" path-glj | tail -1)
    if [[ -x $glj_path ]]; then
      echo "$glj_path"
      exit
    fi
    echo "Error: could not resolve glj path (got: $glj_path)" >&2
    exit 1
  fi

  setup

  # Single-pass scan: extract bash-level flags and build proc_args for getopt.
  # --repl=dir has an optional value getopt doesn't support, so we normalize
  # --repl=dir → --repl (boolean) and save the dir separately.
  # Args after -- are captured as run_args for --shell handling.
  repl_val=
  opt_repl=
  opt_nrepl=
  nrepl_val=
  opt_srepl=
  srepl_val=
  opt_deps=
  opt_shell=
  opt_shellall=
  run_args=()
  proc_args=()
  past_dashdash=

  for arg in "$@"; do
    if [[ -n $past_dashdash ]]; then
      run_args+=("$arg")
      proc_args+=("$arg")
    else
      case $arg in
        --)          past_dashdash=1;          proc_args+=("$arg") ;;
        --repl)      opt_repl=true;            proc_args+=("$arg") ;;
        --repl=*)    opt_repl=true
                     repl_val=${arg#--repl=}
                     proc_args+=(--repl)       ;;
        --nrepl)     opt_nrepl=true;            proc_args+=("$arg") ;;
        --nrepl=*)   opt_nrepl=true
                     nrepl_val=${arg#--nrepl=}
                     proc_args+=(--nrepl)      ;;
        --srepl)     opt_srepl=true;            proc_args+=("$arg") ;;
        --srepl=*)   opt_srepl=true
                     srepl_val=${arg#--srepl=}
                     proc_args+=(--srepl)      ;;
        --deps=*)    opt_deps=${arg#--deps=}
                     proc_args+=("$arg")       ;;
        --shell)     opt_shell=true;           proc_args+=("$arg") ;;
        --shell-all) opt_shellall=true;        proc_args+=("$arg") ;;
        *)           proc_args+=("$arg")       ;;
      esac
    fi
  done

  # Run getopt for --help/--version display, flag validation, and GLOAT_OPTS
  opts_edn=$(printf '%s\n' "$GETOPT_SPEC" | \
    "$root/util/getopt" ${proc_args[@]+"${proc_args[@]}"}) || exit $?

  # --deps without --repl or --nrepl is an error
  if [[ -n $opt_deps && -z $opt_repl && -z $opt_nrepl && -z $opt_srepl ]]; then
    echo "Error: --deps requires --repl or --nrepl" >&2
    exit 1
  fi

  # Handle --shell-all / --shell
  if [[ -n $opt_shellall || -n $opt_shell ]]; then
    if [[ -n $opt_shellall ]]; then
      make --quiet --no-print-directory -C "$root" shell-deps
    else
      make --quiet --no-print-directory -C "$root" shell-deps-min
    fi

    if [[ ${#run_args[@]} -gt 0 ]]; then
      if [[ ${#run_args[@]} -eq 1 ]]; then
        exec bash -c "${run_args[0]}"
      else
        exec "${run_args[@]}"
      fi
    else
      do-shell
    fi
  fi

  # Find local glj binary and add to PATH
  find-glj() {
    local glojure_dir local_glj
    glojure_dir=${GLOJURE_DIR:-$root/../glojure}
    local_glj=$glojure_dir/bin/$(go env GOOS)_$(go env GOARCH)/glj
    if [[ -x $local_glj ]]; then
      PATH=$(dirname "$local_glj"):$PATH
    fi
  }

  # Start an external tool's nREPL server and connect to it
  start-tool-nrepl() {
    local tool=$1
    local cmd bin port=

    local make_target
    case $tool in
      bb)       make_target=which-bb ;;
      lein)     make_target=which-lein ;;
      clj)      make_target=which-clj ;;
      let-go|lg) make_target=which-lg ;;
      *)
        echo "Error: unknown tool '+$tool'" >&2
        echo "Supported: +bb, +lein, +clj, +let-go" >&2
        exit 1
        ;;
    esac

    local local_bin=$root/.cache/local/bin
    local tool_bin=$local_bin/${make_target#which-}
    if [[ ! -x $tool_bin ]]; then
      echo "Installing '$tool' locally..." >&2
    fi
    bin=$(make --quiet --no-print-directory -C "$root" "$make_target" | tail -1)

    case $tool in
      bb)
        cmd=("$bin" nrepl-server localhost:0)
        ;;
      lein)
        cmd=("$bin" repl :headless)
        ;;
      clj)
        cmd=("$bin"
          -Sdeps '{:deps {nrepl/nrepl {:mvn/version "1.3.0"}}}'
          -M -m nrepl.cmdline)
        ;;
      let-go|lg)
        cmd=("$bin" -n)
        ;;
      *)
        echo "Error: unknown tool '+$tool'" >&2
        echo "Supported: +bb, +lein, +clj, +let-go" >&2
        exit 1
        ;;
    esac

    # Start nREPL server in background, capture port from output
    local fifo
    fifo=$(mktemp -u)
    mkfifo "$fifo"

    "${cmd[@]}" > "$fifo" 2>&1 &
    local server_pid=$!
    # shellcheck disable=SC2064
    trap "kill $server_pid 2>/dev/null; rm -f '$fifo'" EXIT

    # Read lines until we find the port
    while IFS= read -r line; do
      if [[ $line =~ :([0-9]+)$ ]] ||
         [[ $line =~ port\ ([0-9]+) ]]; then
        port=${BASH_REMATCH[1]}
        break
      fi
    done < "$fifo"

    # Keep draining the fifo in background so server doesn't block
    cat "$fifo" > /dev/null &

    if [[ -z $port ]]; then
      echo "Error: could not detect nREPL port from $tool" >&2
      exit 1
    fi

    echo "$tool nREPL server on port $port (pid $server_pid)"

    # Use tool-specific history file if env var is set.
    # e.g. GLOAT_REPL_HISTORY_BB=~/.bb_repl_history
    local tool_key=${tool^^}
    tool_key=${tool_key//-/_}
    local hist_var=GLOAT_REPL_HISTORY_${tool_key}
    local hist=${!hist_var:-}

    find-glj
    local hist_flag=()
    [[ -n $hist ]] && hist_flag=(--history "$hist" --history-fmt jline)
    glj --nrepl-connect "localhost:$port" "${hist_flag[@]}"
  }

  # Set up go.mod in CWD to point at the right glojure source.
  setup-go-module() {
    if [[ ! -f go.mod ]]; then
      go mod init gloatrepl
    fi
    if ! grep -q "gloathub/glojure" go.mod 2>/dev/null; then
      local glojure_dir
      glojure_dir=${GLOJURE_DIR:-$(
        make --quiet --no-print-directory -C "$root" path-glojure | tail -1
      )}
      if [[ -d $glojure_dir ]]; then
        go mod edit \
          -replace "github.com/gloathub/glojure=$glojure_dir"
        cp "$glojure_dir/go.sum" go.sum
        # Go does not inherit replace directives from required modules,
        # so mirror glojure's own replaces (e.g. its readline fork).
        local rep_old rep_new
        while IFS=$'\t' read -r rep_old rep_new; do
          [[ -n $rep_old && -n $rep_new ]] || continue
          go mod edit -replace "$rep_old=$rep_new"
        done < <(
          awk '
            /^replace[[:space:]]*\(/ { inblock=1; next }
            inblock && /^[[:space:]]*\)/ { inblock=0; next }
            inblock || /^replace[[:space:]]/ {
              sub(/^replace[[:space:]]+/, "")
              sub(/[[:space:]]*\/\/.*$/, "")
              sub(/^[[:space:]]+/, "")
              if ($0 == "") next
              n = split($0, parts, /[[:space:]]+=>[[:space:]]+/)
              if (n != 2) next
              old = parts[1]; new = parts[2]
              if (split(old, op, /[[:space:]]+/) == 2) old = op[1] "@" op[2]
              if (split(new, np, /[[:space:]]+/) == 2) new = np[1] "@" np[2]
              print old "\t" new
            }
          ' "$glojure_dir/go.mod"
        )
        go get github.com/gloathub/glojure
      else
        local glj_ver
        glj_ver=$(glj --version 2>/dev/null |
          grep -oP 'v\d+\.\d+\.\S+' | head -1 || true)
        go get "github.com/gloathub/glojure@${glj_ver:-latest}"
      fi
    fi
  }

  # Resolve deps file + build dir, write gljdeps.edn, set up go module + env.
  # Optional first arg: explicit build dir hint (used by --repl=dir).
  prepare-repl-env() {
    local build_hint=${1-}

    # Resolve deps file: --deps= flag, GLOAT_GLJDEPS env var, or CWD auto-detect
    local deps_file=$opt_deps
    local explicit_deps=
    if [[ -n $deps_file ]]; then
      explicit_deps=1
    elif [[ -n ${GLOAT_GLJDEPS-} ]]; then
      deps_file=$GLOAT_GLJDEPS
      explicit_deps=1
    elif [[ -f ./gljdeps.edn ]]; then
      deps_file=$(pwd)/gljdeps.edn
    fi

    if [[ -n $deps_file && ! -r $deps_file ]]; then
      echo "Error: $deps_file not found" >&2
      exit 1
    fi

    # Read deps content before cd (handles /dev/fd/N process substitution)
    local deps_content=
    [[ -n $deps_file ]] && deps_content=$(cat "$deps_file")

    # Reject empty / whitespace / comment-only deps files; glj can't parse them
    if [[ -n $deps_file ]]; then
      local deps_stripped
      deps_stripped=$(printf '%s' "$deps_content" | sed 's/;.*$//' |
        tr -d '[:space:]')
      if [[ -z $deps_stripped ]]; then
        cat >&2 <<EOF
Error: $deps_file has no edn content.

A minimal gljdeps.edn declares zero or more Go module deps as edn. Try:

  {:deps {}}                  ; no extra deps
  {:deps {github.com:google:uuid {:mvn/version "v1.6.0"}}}
EOF
        exit 1
      fi
    fi

    # Determine build directory:
    #   build_hint (--repl=dir)  >  GLOAT_REPL  >
    #   ./gljrepl/  (when ./gljdeps.edn was auto-detected)  >
    #   .cache/repl-$GLOAT_VERSION/
    local build_dir
    if [[ -n $build_hint ]]; then
      build_dir=$build_hint
    elif [[ -n ${GLOAT_REPL-} ]]; then
      build_dir=$GLOAT_REPL
    elif [[ -z $explicit_deps && -f ./gljdeps.edn ]]; then
      build_dir=./gljrepl
    else
      build_dir=$root/.cache/repl-$GLOAT_VERSION
    fi

    mkdir -p "$build_dir"
    cd "$build_dir"

    if [[ -n $deps_content ]]; then
      printf '%s\n' "$deps_content" > gljdeps.edn
    fi

    setup-go-module

    export GOFLAGS=-mod=mod

    : "${GOARCH:=$(go env GOARCH)}"
    export GOARCH

    find-glj
  }

  # Handle --repl
  if [[ -n $opt_repl ]]; then
    # --repl=VALUE heuristic: digits=port, file=portfile, dir=builddir
    if [[ -n $repl_val ]]; then
      if [[ $repl_val =~ ^[0-9]+$ ]]; then
        # Port number -- connect to nREPL server
        find-glj
        exec glj --nrepl-connect "localhost:$repl_val"
      elif [[ $repl_val =~ : && ${repl_val##*:} =~ ^[0-9]+$ ]]; then
        # host:port -- connect to nREPL server
        find-glj
        exec glj --nrepl-connect "$repl_val"
      elif [[ $repl_val == +* ]]; then
        # +tool -- start tool's nREPL server, connect to it
        start-tool-nrepl "${repl_val#+}"
        exit
      elif [[ -f $repl_val ]]; then
        # Existing file -- read port from it
        port=$(cat "$repl_val")
        if [[ ! $port =~ ^[0-9]+$ ]]; then
          echo "Error: $repl_val does not contain a valid port number" >&2
          exit 1
        fi
        find-glj
        exec glj --nrepl-connect "localhost:$port"
      elif [[ ! -d $repl_val && $repl_val != */ ]]; then
        # Not a directory and no trailing slash -- error.
        # Trailing slash signals "use as build dir, create if missing".
        echo "Error: '$repl_val' is not a directory or port file." >&2
        echo "To use a new build directory, add a trailing slash:" >&2
        echo "    gloat --repl=$repl_val/" >&2
        exit 1
      fi
      # Fall through: repl_val is a directory or ends with /
    fi

    prepare-repl-env "$repl_val"

    echo "🐐 Gloat: $GLOAT_VERSION 🐐" >&2

    # Run glj in a restart loop so crashes (e.g. stack overflow) don't
    # lose the session. History is persisted to ~/.glj_history.
    while true; do
      glj
      rc=$?
      [[ $rc -eq 0 ]] && break
      echo "" >&2
      echo "REPL crashed (exit $rc), restarting..." >&2
    done
    exit 0
  fi

  # Handle --nrepl
  if [[ -n $opt_nrepl ]]; then
    # Resolve relative port file path before cd into build dir
    if [[ -n $nrepl_val && ! $nrepl_val =~ ^[0-9]+$ &&
          ! ($nrepl_val =~ : && ${nrepl_val##*:} =~ ^[0-9]+$) &&
          $nrepl_val != /* ]]; then
      nrepl_val=$(pwd)/$nrepl_val
    fi

    prepare-repl-env

    nrepl_flag=--nrepl
    [[ -n $nrepl_val ]] && nrepl_flag="--nrepl=$nrepl_val"
    exec glj "$nrepl_flag"
  fi

  if [[ -n $opt_srepl ]]; then
    # Resolve relative port file path before cd into build dir
    if [[ -n $srepl_val && ! $srepl_val =~ ^[0-9]+$ &&
          ! ($srepl_val =~ : && ${srepl_val##*:} =~ ^[0-9]+$) &&
          $srepl_val != /* ]]; then
      srepl_val=$(pwd)/$srepl_val
    fi

    prepare-repl-env

    srepl_flag=--srepl
    [[ -n $srepl_val ]] && srepl_flag="--srepl=$srepl_val"
    exec glj "$srepl_flag"
  fi

  # Pass parsed opts to gloat.clj via env var — no re-parsing needed
  GLOAT_OPTS="$opts_edn" exec bb "$root/src/gloat.clj"
)

setup() (
  [[ $(command -v bb) == "$root/.cache/local/bin/bb" ]] && return

  if interactive; then
    GREEN=$'\e[1;92m'
    YELLOW=$'\e[1;93m'
    BLUE=$'\e[1;96m'
    BOLD=$'\e[1m'
    RESET=$'\e[0m'

    deps="$YELLOW(bb, glj, go, ys)"

    >&2 cat <<...
$BLUE==> Installing gloat dependencies $deps$BLUE locally into:$RESET

    $root/.cache/local/

${BOLD}Press Enter to continue (or Ctrl-C to cancel)...$RESET
...

      read -r < /dev/tty
  fi

  make -C "$root" path-deps

  if interactive; then
    >&2 echo -e "\n$GREEN==> All gloat dependencies installed.$RESET"
  fi
)

interactive() { [[ -t 0 && -t 1 && -t 2 ]]; }

do-shell() {
  if [[ ${IN_GLOAT_SHELL-} ]]; then
    echo "Already in a gloat shell" >&2
    exit 1
  fi
  export IN_GLOAT_SHELL=1
  local shell
  shell=$(ps -o comm= -p $PPID 2>/dev/null)
  shell=${shell#-}
  shell=${shell:-${GLOAT_SHELL:-bash}}
  echo "Starting gloat $shell shell (type 'exit' to leave)" >&2
  case $shell in
    bash)
      exec bash --rcfile <(cat <<'BASH'
[[ -f ~/.bashrc ]] && source ~/.bashrc
PS1="(gloat) $PS1"
BASH
)
      ;;
    zsh)
      local zdot
      zdot=$(mktemp -d)
      cat > "$zdot/.zshrc" <<'ZSH'
[[ -f "$HOME/.zshrc" ]] && ZDOTDIR=$HOME source "$HOME/.zshrc"
PS1="(gloat) $PS1"
ZSH
      exec env ZDOTDIR="$zdot" zsh
      ;;
    fish)
      exec fish --init-command '
functions -q fish_prompt
  and functions -c fish_prompt _gloat_orig_prompt
  and function fish_prompt
    echo -n "(gloat) "
    _gloat_orig_prompt
  end
'
      ;;
    *)
      exec "$shell"
      ;;
  esac
}

main "$@"
