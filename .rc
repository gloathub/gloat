# shellcheck shell=bash disable=2086

# Works for bash, fish and zsh.

# bash
test -n "$BASH_VERSION" && eval '
GLOAT_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
GLOAT_VERSION=$(make --quiet --no-print-directory \
  -C "$GLOAT_ROOT" gloat-version)
GLOAT_GIT_DIR=$(make --quiet --no-print-directory \
  -C "$GLOAT_ROOT" gloat-git-dir)
PATH=$GLOAT_ROOT/bin:$PATH
MANPATH=$GLOAT_ROOT/man:$(manpath 2>/dev/null)
GLOAT_SHELL=bash
export GLOAT_ROOT GLOAT_VERSION GLOAT_GIT_DIR PATH MANPATH GLOAT_SHELL
if [[ -d $GLOAT_GIT_DIR/../glojure ]]; then
  GLOJURE_DIR=$(cd "$GLOAT_GIT_DIR/../glojure" && pwd -P)
  export GLOJURE_DIR
  source <(make --quiet --no-print-directory \
    -C "$GLOAT_ROOT" glojure-worktree)
fi
if [[ -d $GLOAT_ROOT/.cache/local ]]; then
  source <(gloat --complete bash)
fi
return
'

# fish
test -n "$FISH_VERSION" && eval '
set GLOAT_ROOT (cd (dirname (status filename)) && pwd -P)
set GLOAT_VERSION (make --quiet --no-print-directory \
  -C $GLOAT_ROOT gloat-version)
set GLOAT_GIT_DIR (make --quiet --no-print-directory \
  -C $GLOAT_ROOT gloat-git-dir)
set PATH $GLOAT_ROOT/bin:$PATH
set MANPATH $GLOAT_ROOT/man:(manpath 2>/dev/null)
set -gx GLOAT_ROOT $GLOAT_ROOT
set -gx GLOAT_VERSION $GLOAT_VERSION
set -gx GLOAT_GIT_DIR $GLOAT_GIT_DIR
set -gx GLOAT_SHELL fish
if test -d $GLOAT_GIT_DIR/../glojure
  set -gx GLOJURE_DIR (cd $GLOAT_GIT_DIR/../glojure; and pwd -P)
  make --quiet --no-print-directory \
    -C $GLOAT_ROOT glojure-worktree | source
end
export PATH MANPATH
gloat --complete fish | source
exit
'

# zsh
test -n "$ZSH_VERSION" && eval '
GLOAT_ROOT=$(cd "$(dirname "$0")" && pwd -P)
GLOAT_VERSION=$(make --quiet --no-print-directory \
  -C "$GLOAT_ROOT" gloat-version)
GLOAT_GIT_DIR=$(make --quiet --no-print-directory \
  -C "$GLOAT_ROOT" gloat-git-dir)
PATH=$GLOAT_ROOT/bin:$GLOAT_ROOT/local/bin:$PATH
MANPATH=$GLOAT_ROOT/man:$GLOAT_ROOT/local/man:$(manpath 2>/dev/null)
GLOAT_SHELL=zsh
export GLOAT_ROOT GLOAT_VERSION GLOAT_GIT_DIR PATH MANPATH GLOAT_SHELL
if [[ -d $GLOAT_GIT_DIR/../glojure ]]; then
  GLOJURE_DIR=$(cd "$GLOAT_GIT_DIR/../glojure" && pwd -P)
  export GLOJURE_DIR
  source <(make --quiet --no-print-directory \
    -C "$GLOAT_ROOT" glojure-worktree)
fi
if [[ -d $GLOAT_ROOT/.cache/local ]]; then
  eval "$(gloat --complete zsh)"
fi
return
'

echo "ERROR: gloat/.rc is not set up to work for shell '$0'"
false

# vim: ft=sh:
